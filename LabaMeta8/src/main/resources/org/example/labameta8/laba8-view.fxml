<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="442.0" prefWidth="722.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.labameta8.Laba8Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Label fx:id="statusLabel1" text="Ник" />
         <TextField fx:id="nickField" />
         <ListView fx:id="userListView" prefHeight="200.0" prefWidth="200.0" />
         <Label fx:id="statusLabel11" text="Порт" />
         <TextField fx:id="portField" />
      </children>
   </HBox>

    <Label fx:id="welcomeText" />
   <Label fx:id="statusLabel" text="Label" />
   <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button fx:id="Start1" mnemonicParsing="false" onAction="#onStartWaiting" prefHeight="46.0" prefWidth="98.0" text="Ожидание" />
         <Button fx:id="CallBnt" mnemonicParsing="false" onAction="#onCallButtonClick" prefHeight="46.0" prefWidth="153.0" text="Позвонить из списка" />
         <Button fx:id="BtnCanc" mnemonicParsing="false" onAction="#handleHangUp" prefHeight="46.0" prefWidth="95.0" text="Сброс" />
         <Button fx:id="CallBnt1" mnemonicParsing="false" onAction="#onManualCallClick" prefHeight="46.0" prefWidth="144.0" text="Позвонить по ip" />
      </children>
   </HBox>
   <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Label fx:id="statusLabel12" text="Ip собеседника" />
         <TextField fx:id="UserIp" />
         <Label fx:id="statusLabel121" text="Порт собеседника" />
         <TextField fx:id="UserPort" />
      </children>
   </HBox>
   <Button fx:id="TestBtn" mnemonicParsing="false" onAction="#onManualCallClick" prefHeight="46.0" prefWidth="144.0" text="Позвонить по ip" />
</VBox>
