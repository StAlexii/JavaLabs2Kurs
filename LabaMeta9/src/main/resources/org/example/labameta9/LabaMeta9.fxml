<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="703.0" prefWidth="621.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="org.example.labameta9.Laba9Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <HBox alignment="CENTER" prefHeight="65.0" prefWidth="581.0">
      <children>
         <RadioButton fx:id="rbLevel0" mnemonicParsing="false" selected="true" text="Защита 0" />
         <RadioButton fx:id="rbLevel1" mnemonicParsing="false" text="Защита 1" />
         <RadioButton fx:id="rbLevel2" mnemonicParsing="false" text="Защита 2" />
         <RadioButton fx:id="rbLevel3" mnemonicParsing="false" text="Защита 3" />
      </children>
   </HBox>
   <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Ник" />
   <TextField fx:id="txtNickname" />
   <Button fx:id="btnRegister" mnemonicParsing="false" onAction="#onRegisterClick" text="Регистр" />
   <Label fx:id="lblStatus" text="Label" />
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Кому" />
         <TextField fx:id="txtTarget" />
         <TextArea fx:id="txtMessage" prefHeight="200.0" prefWidth="200.0" />
         <Button fx:id="BtnHint" mnemonicParsing="false" onAction="#onSendHintClick" text="Подсказка" />
         <Button fx:id="btnGuess" mnemonicParsing="false" onAction="#onGuessClick" text="Догадайся" />
      </children>
   </HBox>
   <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Сообщение" />
   <Button fx:id="btnRefreshInbox" mnemonicParsing="false" onAction="#onRefreshInboxClick" prefHeight="41.0" prefWidth="82.0" text="Обновить?" />
   <ListView fx:id="listInbox" prefHeight="200.0" prefWidth="200.0" />
</VBox>
